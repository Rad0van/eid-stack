def muvm_path() -> Path:
    """The muvm binary path baked into wrapper scripts. Prefer ~/.cargo/bin
    if present (user's custom build), else whatever's in PATH."""
    cand = HOME / ".cargo/bin/muvm"
    if cand.exists():
        return cand
    p = shutil.which("muvm")
    if not p:
        die("muvm not found in PATH. Install muvm first (system pkg or cargo build).")
    return Path(p)


def systemctl_user(*args: str, check: bool = True) -> subprocess.CompletedProcess:
    return run(["systemctl", "--user", *args], check=check)


def install_muvm_service() -> None:
    need_cmd("systemctl")
    need_cmd("muvm", "install muvm (system pkg or cargo install --path crates/muvm)")

    # PATH-discoverability: ensure ~/.local/bin/muvm-guest -> ~/.cargo/bin/muvm-guest
    cargo_guest = HOME / ".cargo/bin/muvm-guest"
    if cargo_guest.exists():
        MUVM_GUEST_SYMLINK.parent.mkdir(parents=True, exist_ok=True)
        if MUVM_GUEST_SYMLINK.is_symlink() or MUVM_GUEST_SYMLINK.exists():
            MUVM_GUEST_SYMLINK.unlink()
        MUVM_GUEST_SYMLINK.symlink_to(cargo_guest)
        ok(f"symlinked {MUVM_GUEST_SYMLINK} → {cargo_guest}")
    else:
        warn(f"{cargo_guest} not found; not creating PATH symlink. "
             f"The system muvm-guest (if any) will be used instead, "
             f"which may not have pcscd/loopback bridging.")

    # systemd units
    SYSTEMD_UNIT.parent.mkdir(parents=True, exist_ok=True)
    SYSTEMD_UNIT.write_text(SYSTEMD_UNIT_BODY)
    ok(f"wrote {SYSTEMD_UNIT}")

    # IPv6 loopback shim (see SHIM_UNIT_BODY). Needs socat on the host.
    socat = shutil.which("socat")
    if socat:
        SHIM_UNIT.write_text(SHIM_UNIT_BODY.replace("%SOCAT%", socat))
        ok(f"wrote {SHIM_UNIT}")
    else:
        warn("socat not found; skipping eid-ipv6-shim.service. Brave/Chromium "
             "'localhost' (IPv6 ::1) won't reach eID Klient and portals may report "
             "'eID not running'. Install socat and re-run `eid-stack reinstall muvm-service`.")

    systemctl_user("daemon-reload")
    systemctl_user("enable", "dlauncher2-muvm.service")
    # Restart muvm first so passt rebinds IPv4-only and frees ::1 for the shim.
    systemctl_user("restart", "dlauncher2-muvm.service")
    ok("muvm service started")
    if socat:
        systemctl_user("enable", "eid-ipv6-shim.service")
        systemctl_user("restart", "eid-ipv6-shim.service")
        ok("eid-ipv6-shim service started")

    state_set("muvm-service", source="local")


def uninstall_muvm_service() -> None:
    if SHIM_UNIT.exists():
        systemctl_user("stop", "eid-ipv6-shim.service", check=False)
        systemctl_user("disable", "eid-ipv6-shim.service", check=False)
        SHIM_UNIT.unlink()
        ok(f"removed {SHIM_UNIT}")
    if SYSTEMD_UNIT.exists():
        systemctl_user("stop", "dlauncher2-muvm.service", check=False)
        systemctl_user("disable", "dlauncher2-muvm.service", check=False)
        SYSTEMD_UNIT.unlink()
        systemctl_user("daemon-reload", check=False)
        ok(f"removed {SYSTEMD_UNIT}")
    if MUVM_GUEST_SYMLINK.is_symlink():
        MUVM_GUEST_SYMLINK.unlink()
        ok(f"removed {MUVM_GUEST_SYMLINK}")
    state_drop("muvm-service")


def status_muvm_service() -> dict:
    out = {"installed": SYSTEMD_UNIT.exists(), "active": False,
           "guest_symlink": MUVM_GUEST_SYMLINK.is_symlink(),
           "shim_installed": SHIM_UNIT.exists(), "shim_active": False}
    if out["installed"]:
        # Bypass run() so neither the "$ systemctl …" trace nor systemctl's own
        # "active" stdout leak into `list` output.
        r = subprocess.run(["systemctl", "--user", "is-active", "dlauncher2-muvm.service"],
                           capture_output=True, text=True, check=False)
        out["active"] = (r.returncode == 0)
    if out["shim_installed"]:
        r = subprocess.run(["systemctl", "--user", "is-active", "eid-ipv6-shim.service"],
                           capture_output=True, text=True, check=False)
        out["shim_active"] = (r.returncode == 0)
    return out


