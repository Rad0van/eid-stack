def install_eid_klient() -> None:
    need_cmd("sudo")
    need_cmd("muvm")
    info("eID Klient installs to /usr/lib/eID_klient/ — you'll be prompted for sudo.")

    with tempfile.TemporaryDirectory(prefix="eid-stack-ek-") as td:
        tar_path = Path(td) / "eID_klient.tar.gz"
        headers = download(URL_EID_KLIENT, tar_path)

        # The tar.gz contains a single AppImage (and maybe a checksum file).
        info("extracting tar.gz")
        with tarfile.open(tar_path) as tf:
            tf.extractall(td, filter="data")
        appimages = list(Path(td).rglob("*.AppImage"))
        if not appimages:
            die("no .AppImage found in tar.gz")
        appimage = appimages[0]
        info(f"found {appimage.name}")
        # Try to parse version from filename: only accept VERSION_LIKE captures,
        # because in practice the bundled name is e.g. eID_klient_x86_64.AppImage
        # (platform suffix, not version). The libCardAPI.so scan below is the
        # canonical source.
        m_ver = re.search(r"eID_klient[_\-]([0-9][\w.\-]*?)\.AppImage", appimage.name)
        version_from_name = m_ver.group(1) if m_ver else None

        # Extract via muvm into a staging dir, then sudo-move
        stage = Path(td) / "stage"
        appimage_extract(appimage, stage)

        # Move into /usr/lib/eID_klient/ via sudo
        if EID_KLIENT_ROOT.exists():
            info(f"removing existing {EID_KLIENT_ROOT}")
            run(["sudo", "rm", "-rf", str(EID_KLIENT_ROOT)])
        run(["sudo", "mkdir", "-p", str(EID_KLIENT_ROOT)])
        run(["sudo", "cp", "-a", *[str(p) for p in stage.iterdir()], str(EID_KLIENT_ROOT) + "/"])
        run(["sudo", "chown", "-R", "root:root", str(EID_KLIENT_ROOT)])
        ok(f"installed eID Klient → {EID_KLIENT_ROOT}")

        # PKCS11 path symlink (hardcoded path in DITEC's jar)
        run(["sudo", "ln", "-sf", EID_KLIENT_PKCS11_REAL, str(EID_KLIENT_PKCS11_LINK)])
        ok(f"symlinked {EID_KLIENT_PKCS11_LINK} → {EID_KLIENT_PKCS11_REAL}")

        # VirtualKeyboard symlink (eID_Client looks it up via LD_LIBRARY_PATH=lib/)
        run(["sudo", "ln", "-sf", EID_KLIENT_VK_REAL, str(EID_KLIENT_VK_LINK)])
        ok(f"symlinked {EID_KLIENT_VK_LINK} → {EID_KLIENT_VK_REAL}")

        # Desktop integration: extract share.tar if present, install .desktop + icons (user-side)
        share_tar = EID_KLIENT_ROOT / "share.tar"
        if share_tar.exists():
            with tempfile.TemporaryDirectory(prefix="eid-share-") as sd:
                run(["tar", "-xf", str(share_tar), "-C", sd])
                install_eid_icons(Path(sd))

        # SVG fallback icon (script-level) — copies the high-res logo to a stable name
        svg = EID_KLIENT_ROOT / "sk_logo.svg"
        if svg.exists():
            target = ICON_HICOLOR / "scalable/apps/eid-klient.svg"
            target.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy(svg, target)

        # .desktop
        write_desktop_file(
            DESKTOP_DIR / "eid-klient.desktop",
            Type="Application",
            Name="eID klient",
            **{"Name[sk]": "eID klient"},
            GenericName="Slovak electronic ID middleware",
            Comment="Slovak eID middleware (DITEC)",
            Exec=str(WRAPPER_EID),
            Icon="eid-klient",
            Categories="Office;Security;X-DITEC;",
            Terminal="false",
        )
        ok(f"wrote {DESKTOP_DIR / 'eid-klient.desktop'}")

        # Wrapper
        WRAPPER_EID.parent.mkdir(parents=True, exist_ok=True)
        body = (WRAPPER_EID_BODY
                .replace("%MUVM%", str(muvm_path()))
                .replace("%EID_ROOT%", str(EID_KLIENT_ROOT)))
        WRAPPER_EID.write_text(body)
        WRAPPER_EID.chmod(0o755)
        ok(f"wrote wrapper {WRAPPER_EID}")

    refresh_desktop_db()

    # libCardAPI.so is authoritative (CardAPI prints this string at runtime).
    # Filename is a weak fallback because the bundled AppImage often only has
    # a platform suffix in its name.
    state_set("eid-klient", source=URL_EID_KLIENT, version=None,
              etag=headers.get("ETag"),
              last_modified=headers.get("Last-Modified"))
    version = detect_eid_version() or version_from_name or "unknown"
    state_set("eid-klient", version=version)
    ok(f"eID Klient version: {version}")


def install_eid_icons(share_root: Path) -> None:
