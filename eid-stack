# === Output helpers =======================================================

def _isatty() -> bool:
    return sys.stderr.isatty()

def _c(msg: str, color: str) -> str:
    if not _isatty():
        return msg
    codes = {"red": 31, "green": 32, "yellow": 33, "blue": 34, "gray": 90, "bold": 1}
    return f"\033[{codes[color]}m{msg}\033[0m"

def info(msg: str) -> None:
    print(_c("→ ", "blue") + msg, file=sys.stderr)

def ok(msg: str) -> None:
    print(_c("✓ ", "green") + msg, file=sys.stderr)

def warn(msg: str) -> None:
    print(_c("! ", "yellow") + msg, file=sys.stderr)

def die(msg: str, code: int = 1) -> "Never":  # type: ignore[valid-type]
    print(_c("✗ ", "red") + msg, file=sys.stderr)
    sys.exit(code)


# === Subprocess helpers ===================================================

def run(cmd, *, check: bool = True, capture: bool = False, **kw) -> subprocess.CompletedProcess:
    if isinstance(cmd, str):
        echo = cmd
        kw.setdefault("shell", True)
    else:
        cmd = [str(c) for c in cmd]
        echo = " ".join(cmd)
    print(_c(f"  $ {echo}", "gray"), file=sys.stderr)
    return subprocess.run(cmd, check=check, capture_output=capture, text=True, **kw)


def run_in_vm(script: str) -> subprocess.CompletedProcess:
    """Run a bash snippet inside the muvm VM. Uses pipe stdin to avoid the
    EPERM that `muvm -i` raises with regular-file stdin."""
    return subprocess.run(
        ["muvm", "-i", "--", "bash", "-c", script],
        check=True, text=True,
        input="",   # forces a pipe stdin (not /dev/null)
    )


def need_cmd(name: str, hint: str = "") -> None:
    if not shutil.which(name):
        msg = f"required command not in PATH: {name}"
        if hint:
            msg += f"\n   hint: {hint}"
        die(msg)


# === HTTP helpers =========================================================

USER_AGENT = "eid-stack/1.0 (+https://www.slovensko.sk)"

def http_get(url: str) -> tuple[bytes, dict]:
    req = urllib.request.Request(url, headers={"User-Agent": USER_AGENT})
    with urllib.request.urlopen(req, timeout=60) as r:
        return r.read(), dict(r.headers)

def http_head(url: str) -> dict:
    req = urllib.request.Request(url, method="HEAD", headers={"User-Agent": USER_AGENT})
    try:
        with urllib.request.urlopen(req, timeout=30) as r:
            return dict(r.headers)
    except urllib.error.HTTPError as e:
        if e.code == 405:  # method not allowed → fall back to a 1-byte GET
            req = urllib.request.Request(url, headers={"User-Agent": USER_AGENT, "Range": "bytes=0-0"})
            with urllib.request.urlopen(req, timeout=30) as r:
                return dict(r.headers)
        raise

def download(url: str, dest: Path) -> dict:
    dest.parent.mkdir(parents=True, exist_ok=True)
    req = urllib.request.Request(url, headers={"User-Agent": USER_AGENT})
    info(f"download {url}")
    with urllib.request.urlopen(req, timeout=120) as r:
        total = int(r.headers.get("Content-Length") or 0)
        headers = dict(r.headers)
        got = 0
        last = 0
        with open(dest, "wb") as f:
            while True:
                chunk = r.read(256 * 1024)
                if not chunk:
                    break
                f.write(chunk)
                got += len(chunk)
                if total and _isatty() and got - last > 2 * 1024 * 1024:
                    print(_c(f"    {got//1024//1024} / {total//1024//1024} MB", "gray"),
                          file=sys.stderr, end="\r")
                    last = got
        if _isatty():
            print(" " * 40, file=sys.stderr, end="\r")
    return headers


# === State ================================================================

def state_load() -> dict:
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except json.JSONDecodeError:
            warn(f"corrupt state file at {STATE_FILE}; ignoring")
    return {}

def state_save(state: dict) -> None:
    STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(state, indent=2) + "\n")

def state_set(component: str, **fields) -> None:
    s = state_load()
    entry = s.setdefault(component, {})
    entry.update(fields)
    entry["updated_at"] = datetime.now(timezone.utc).isoformat(timespec="seconds")
    state_save(s)

def state_drop(component: str) -> None:
    s = state_load()
    s.pop(component, None)
    state_save(s)


# === AppImage extraction ==================================================

def appimage_extract(appimage_path: Path, dest_dir: Path) -> None:
    """Run AppImage --appimage-extract inside the muvm VM (x86_64 via FEX).
    The AppImage extracts into ./squashfs-root/ in cwd; we then rsync to
    dest_dir (replacing it)."""
    appimage_path = appimage_path.resolve()
    dest_dir.parent.mkdir(parents=True, exist_ok=True)
    appimage_path.chmod(0o755)
    with tempfile.TemporaryDirectory(prefix="eid-stack-ax-") as td:
        info(f"extract AppImage {appimage_path.name} (in muvm)")
        run_in_vm(
            f"cd '{td}' && '{appimage_path}' --appimage-extract >/dev/null"
        )
        src = Path(td) / "squashfs-root"
        if not src.is_dir():
            die(f"AppImage extraction did not produce {src}")
        if dest_dir.exists():
            shutil.rmtree(dest_dir)
        # Use rsync if available (preserves symlinks and is fast); otherwise copytree.
        if shutil.which("rsync"):
            run(["rsync", "-a", f"{src}/", f"{dest_dir}/"])
        else:
            shutil.copytree(src, dest_dir, symlinks=True)


# === Desktop integration ==================================================

def write_desktop_file(path: Path, **fields) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    body = "[Desktop Entry]\n"
    for k, v in fields.items():
        body += f"{k}={v}\n"
    path.write_text(body)
    path.chmod(0o644)

def refresh_desktop_db() -> None:
    for cmd in (["update-desktop-database", str(DESKTOP_DIR)],
                ["gtk-update-icon-cache", "-t", str(ICON_HICOLOR)]):
        if shutil.which(cmd[0]):
            try:
                run(cmd, check=False, capture=True)
            except Exception:
                pass


# === SHA256 ================================================================

def sha256_b64(data: bytes) -> str:
    return base64.b64encode(hashlib.sha256(data).digest()).decode()

def sha256_b64_file(path: Path) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1 << 20), b""):
            h.update(chunk)
    return base64.b64encode(h.digest()).decode()


