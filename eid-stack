MUVM_REPO = HOME / "Programming/muvm"
MUVM_FORK_URL = "git@github.com:Rad0van/muvm.git"
MUVM_FORK_BRANCH = "pcscd"
APT_FEX_PKGS = ["fex-emu-armv8.4", "fex-emu-binfmt64", "fex-emu-binfmt32"]

# FEX's RootFS server has no Ubuntu 25.10, but the DITEC eID stack only works with
# 25.10 on this box (24.04 fails). This is the community "Stage2" 25.10 x86_64 FEX
# rootfs (a full GUI package set, not minimal ubuntu-base); the tarball extracts
# flat into the RootFS dir.
URL_FEX_ROOTFS = "https://kernelpanik.net/content/images/Stage2_ubuntu-base-25.10-base-amd64.tar.gz"
FEX_ROOTFS_NAME = "Ubuntu_25_10"


def _have_so(stem: str) -> bool:
    """True if a shared library lib<stem>.so* exists under /usr/lib."""
    return any(Path("/usr/lib").glob(f"*/{stem}.so*")) or \
           any(Path("/usr/lib").glob(f"{stem}.so*"))


def _fex_rootfs() -> tuple[bool, str]:
    cfg = HOME / ".fex-emu/Config.json"
    if not cfg.exists():
        return False, "no ~/.fex-emu/Config.json — `eid-stack deps install`"
    try:
        name = json.loads(cfg.read_text()).get("Config", {}).get("RootFS", "")
    except Exception:
        name = ""
    if not name:
        return False, "no RootFS selected in Config.json — `eid-stack deps install`"
    base = HOME / ".fex-emu/RootFS"
    if any((base / cand).exists() for cand in (name, f"{name}.sqsh", f"{name}.ero")):
        return True, f"~/.fex-emu/RootFS/{name}"
    return False, f"RootFS '{name}' configured but not present in ~/.fex-emu/RootFS"


def _set_fex_default_rootfs(name: str) -> None:
    """Set Config.RootFS in ~/.fex-emu/Config.json, preserving other keys."""
    cfg_path = HOME / ".fex-emu/Config.json"
    cfg = {}
    if cfg_path.exists():
        try:
            cfg = json.loads(cfg_path.read_text())
        except Exception:
            cfg = {}
    cfg.setdefault("Config", {})["RootFS"] = name
    cfg_path.parent.mkdir(parents=True, exist_ok=True)
    cfg_path.write_text(json.dumps(cfg))


def _apt_install(pkgs: list[str]) -> None:
    need_cmd("sudo")
    need_cmd("apt-get")
    run(["sudo", "apt-get", "install", "-y", *pkgs])


def _fix_socat() -> None:
    _apt_install(["socat"])


def _fix_fex() -> None:
    info("installing FEX (needs the FEX apt repo configured)")
    _apt_install(APT_FEX_PKGS)


def _fix_rootfs() -> None:
    dest = HOME / ".fex-emu/RootFS" / FEX_ROOTFS_NAME
    if dest.exists():
        info(f"RootFS dir already present: {dest} — setting as default only")
        _set_fex_default_rootfs(FEX_ROOTFS_NAME)
        ok(f"FEX RootFS default = {FEX_ROOTFS_NAME}")
        return
    # FEXRootFSFetcher can't get 25.10 (not on the FEX server); fetch the Stage2 tarball.
    # Extract with system `tar` (not tarfile's "data" filter, which would reject the
    # absolute symlinks an OS rootfs legitimately contains) — same as a manual `tar -xf`.
    need_cmd("tar")
    with tempfile.TemporaryDirectory() as td:
        tarball = Path(td) / "rootfs.tar.gz"
        download(URL_FEX_ROOTFS, tarball)
        info(f"extracting RootFS into {dest} (large — ~2.8 GB, takes a while)")
        dest.mkdir(parents=True, exist_ok=True)
        run(["tar", "-xzf", str(tarball), "-C", str(dest)])
    _set_fex_default_rootfs(FEX_ROOTFS_NAME)
    ok(f"installed FEX RootFS {FEX_ROOTFS_NAME} and set as default")


def _fix_muvm() -> None:
    need_cmd("cargo", "install Rust via rustup: https://rustup.rs")
    need_cmd("git")
    if not MUVM_REPO.exists():
        info(f"cloning {MUVM_FORK_URL} (branch {MUVM_FORK_BRANCH}) -> {MUVM_REPO}")
        MUVM_REPO.parent.mkdir(parents=True, exist_ok=True)
        run(["git", "clone", "-b", MUVM_FORK_BRANCH, MUVM_FORK_URL, str(MUVM_REPO)])
    else:
        info(f"using existing muvm checkout at {MUVM_REPO}")
    info("building muvm (cargo build --release)")
    run(["cargo", "build", "--release"], cwd=str(MUVM_REPO))
    cargo_bin = HOME / ".cargo/bin"
    cargo_bin.mkdir(parents=True, exist_ok=True)
    for b in ("muvm", "muvm-guest"):
        src = MUVM_REPO / "target/release" / b
        if not src.exists():
            die(f"build did not produce {src}")
        # Stage in the same dir then atomically rename over the target, so a
        # re-run while the persistent VM is using the old `muvm` doesn't fail
        # with ETXTBSY ("Text file busy") — rename unlinks the in-use inode and
        # the running process keeps its mapped copy.
        dst = cargo_bin / b
        tmp = cargo_bin / f".{b}.new"
        shutil.copy2(src, tmp)
        tmp.chmod(0o755)
        os.replace(tmp, dst)
    ok(f"installed muvm + muvm-guest to {cargo_bin}")


def _deps() -> list[tuple]:
    """[(name, ok, detail, fixer|None)]; fixer runs on `deps install`."""
    cargo = shutil.which("cargo")
    fex = shutil.which("FEXInterpreter")
    rok, rdetail = _fex_rootfs()
    muvm = bool((HOME / ".cargo/bin/muvm").exists() or shutil.which("muvm"))
    socat = shutil.which("socat")
    dpkgdeb = shutil.which("dpkg-deb")
    return [
        ("cargo (Rust; builds muvm)", bool(cargo),
         cargo or "install Rust via rustup (https://rustup.rs)", None),
        ("FEX (x86_64 emulation)", bool(fex),
         fex or f"apt: {' '.join(APT_FEX_PKGS)}", _fix_fex),
        ("FEX RootFS (x86 system libs)", rok, rdetail, _fix_rootfs),
        ("libkrun (muvm VM backend)", _have_so("libkrun"),
         "present" if _have_so("libkrun") else "missing — Asahi gaming PPA (see README)", None),
        ("libkrunfw (VM kernel image)", _have_so("libkrunfw"),
         "present" if _have_so("libkrunfw") else "missing — Asahi gaming PPA (see README)", None),
        (f"muvm (fork, branch {MUVM_FORK_BRANCH})", muvm,
         str(HOME / ".cargo/bin/muvm") if muvm else f"build from fork ({MUVM_FORK_URL})", _fix_muvm),
        ("socat (IPv6 localhost shim)", bool(socat), socat or "apt: socat", _fix_socat),
        ("dpkg-deb (WebSigner .deb)", bool(dpkgdeb), dpkgdeb or "apt: dpkg", None),
    ]


def cmd_deps(do_install: bool) -> None:
    deps = _deps()
    if do_install:
        missing = [(n, fx) for (n, okk, _d, fx) in deps if not okk]
        if not missing:
            ok("all prerequisites already satisfied")
        for name, fx in missing:
            if fx is None:
                warn(f"{name}: no automatic install — see `eid-stack deps`")
                continue
            info(f"=== installing: {name} ===")
            fx()
        deps = _deps()  # re-check after installing
    info("prerequisite status:")
    width = max(len(n) for (n, *_r) in deps)
    for name, okk, detail, _fx in deps:
        mark, color = ("✓", "green") if okk else ("✗", "red")
        print(_c(f"  {mark} {name.ljust(width)}  {detail}", color), file=sys.stderr)
    if not do_install and any(not okk for (_n, okk, _d, _f) in deps):
        info("run `eid-stack deps install` to install the automatable ones")


def parse_components(args: list[str], *, default_to: list[str]) -> list[str]:
    if not args or args == ["all"]:
        return list(default_to)
    bad = [a for a in args if a not in ALL_COMPONENTS]
    if bad:
        die(f"unknown component(s): {', '.join(bad)}. Known: {', '.join(ALL_COMPONENTS)}")
    return args


def main() -> None:
    p = argparse.ArgumentParser(prog="eid-stack", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("command", choices=["install", "update", "reinstall", "uninstall", "list", "deps", "help"],
                   help="action to perform")
    p.add_argument("components", nargs="*", help="components (default: all); for `deps`: optional 'install'")
    args = p.parse_args()

    if args.command == "help":
        p.print_help()
        return
    if args.command == "list":
        cmd_list()
        return
    if args.command == "deps":
        sub = args.components
        if sub and sub != ["install"]:
            die("usage: eid-stack deps [install]")
        cmd_deps(do_install=(sub == ["install"]))
        return

    if args.command in ("install", "reinstall"):
        comps = parse_components(args.components, default_to=ALL_COMPONENTS)
        (cmd_reinstall if args.command == "reinstall" else cmd_install)(comps)
    elif args.command == "uninstall":
        # default uninstall scope: only what's currently installed
        installed = [c for c in ALL_COMPONENTS if c in state_load()]
        comps = parse_components(args.components, default_to=installed)
        cmd_uninstall(comps)
    elif args.command == "update":
        installed = [c for c in ALL_COMPONENTS if c in state_load()]
        comps = parse_components(args.components, default_to=installed)
        cmd_update(comps)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        die("interrupted")
    except subprocess.CalledProcessError as e:
        die(f"command failed: {e}")
