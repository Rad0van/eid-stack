def write_nm_manifests() -> list[Path]:
    manifest = {
        "name": NM_NAME,
        "description": "D.Bridge 2 native messaging host",
        "path": str(WRAPPER_DBRIDGE),
        "type": "stdio",
        "allowed_origins": [f"chrome-extension://{e}/" for e in DBRIDGE_EXTENSIONS],
    }
    body = json.dumps(manifest, indent=2) + "\n"
    written = []
    for name, dirpath in NM_BROWSERS.items():
        if dirpath.parent.parent.exists() or name == "brave":
            # write into any browser whose root config exists, OR brave (we recommend it)
            dirpath.mkdir(parents=True, exist_ok=True)
            target = dirpath / f"{NM_NAME}.json"
            target.write_text(body)
            target.chmod(0o644)
            written.append(target)
            ok(f"wrote NM manifest: {target}")
    return written


def install_dlauncher() -> None:
    need_cmd("muvm")

    with tempfile.TemporaryDirectory(prefix="eid-stack-dl-") as td:
        run_path = Path(td) / "DLauncher2.run"
        headers = download(URL_DLAUNCHER, run_path)

        appimage_extract(run_path, DLAUNCHER_ROOT)

        # The D.Launcher 2.x AppImage nests its real payload under an inner
        # dlauncher2/ dir (its AppRun execs $HERE/dlauncher2/dLauncher2), but our
        # installation.xml <Path> and the NM wrapper expect dLauncher2/dBridge2Nm
        # at DLAUNCHER_ROOT top level (binaries find their Qt libs as siblings via
        # $ORIGIN, which still holds after the move). Flatten the inner dir up if
        # the binary didn't land at the top. No-op for a flat AppImage.
        if not (DLAUNCHER_ROOT / "dLauncher2").exists():
            inner = next((p.parent for p in DLAUNCHER_ROOT.glob("*/dLauncher2")), None)
            if inner is None:
                die("dLauncher2 binary not found after AppImage extraction")
            info(f"flattening nested payload {inner.name}/ → top level")
            for item in list(inner.iterdir()):
                target = DLAUNCHER_ROOT / item.name
                if target.is_dir() and not target.is_symlink():
                    shutil.rmtree(target)
                elif target.exists() or target.is_symlink():
                    target.unlink()
                shutil.move(str(item), str(target))
            inner.rmdir()
        ok(f"installed D.Launcher → {DLAUNCHER_ROOT}")

        # Detect version from the embedded AppRun or a binary if available.
        version = detect_dlauncher_version(DLAUNCHER_ROOT)
        if version:
            ok(f"detected D.Launcher version {version}")
        else:
            version = "2.x"
            warn("could not detect D.Launcher version; using '2.x' placeholder")

        # installation.xml
        DLAUNCHER_INSTALL_XML.parent.mkdir(parents=True, exist_ok=True)
        install_xml_body = textwrap.dedent(f"""\
            <?xml version="1.0" encoding="UTF-8"?>
            <Installation xmlns="http://www.ditec.sk/ep/products/dlauncher/configuration/installation/v1.0">
                <Version>{version}</Version>
                <Path>{DLAUNCHER_ROOT}/dLauncher2</Path>
            </Installation>
            """)
        DLAUNCHER_INSTALL_XML.write_text(install_xml_body)
        ok(f"wrote {DLAUNCHER_INSTALL_XML}")

        # Wrapper
        WRAPPER_DBRIDGE.parent.mkdir(parents=True, exist_ok=True)
        body = (WRAPPER_DBRIDGE_BODY
                .replace("%MUVM%", str(muvm_path()))
                .replace("%DBRIDGE_BIN%", str(DLAUNCHER_ROOT / "dBridge2Nm")))
        WRAPPER_DBRIDGE.write_text(body)
        WRAPPER_DBRIDGE.chmod(0o755)
        ok(f"wrote wrapper {WRAPPER_DBRIDGE}")

        # NM manifests
        write_nm_manifests()

        info("D.Bridge 2 browser extension must be installed manually:")
        info("    Chrome/Brave: https://chrome.google.com/webstore/detail/dbridge-2/fngbdhimbgbonhlibfmiemipheabfdmj")
        info("    Firefox:      https://addons.mozilla.org/sk/firefox/addon/d-bridge-2/")

    state_set("dlauncher",
              source=URL_DLAUNCHER,
              version=version,
              etag=headers.get("ETag"),
              last_modified=headers.get("Last-Modified"))


def uninstall_dlauncher() -> None:
    paths = [DLAUNCHER_ROOT, DLAUNCHER_INSTALL_XML, WRAPPER_DBRIDGE]
    for d in NM_BROWSERS.values():
        p = d / f"{NM_NAME}.json"
        if p.exists():
            paths.append(p)
    for p in paths:
        remove_path(p)
    state_drop("dlauncher")


def detect_dlauncher_version(root: Path) -> Optional[str]:
    """Look for a version string in metadata / AppRun / .desktop."""
    for cand in [root / "dlauncher2.desktop", root / ".version", root / "AppRun"]:
        if cand.exists():
            try:
                text = cand.read_text(errors="ignore")
            except Exception:
                continue
            m = re.search(r"\b(2\.\d+\.\d+\.\d+)\b", text)
            if m:
                return m.group(1)
    return None


def status_dlauncher() -> dict:
    if not DLAUNCHER_ROOT.exists():
        return {"installed": False}
    version = None
    if DLAUNCHER_INSTALL_XML.exists():
        try:
            t = DLAUNCHER_INSTALL_XML.read_text()
            m = re.search(r"<Version>([^<]+)</Version>", t)
            if m:
                version = m.group(1)
        except Exception:
            pass
    return {"installed": True, "version": version, "wrapper": WRAPPER_DBRIDGE.exists()}


