def detect_eid_version() -> Optional[str]:
    """Prefer state.json (captured at install time from the AppImage filename);
    fall back to scanning libCardAPI.so for the version literal that CardAPI
    prints as 'CardAPI, version: %s' at runtime (e.g. 'v5.3_RC2').
    Other v5.x tokens in the same binary are card-profile compatibility checks
    (v5.0, v5.4, v6.0, …) — we filter to a tagged form (_RC, _GA, _beta) and
    only fall back to a bare X.Y.Z if no tagged form is present."""
    saved = state_load().get("eid-klient", {}).get("version")
    if saved:
        return saved
    card_api = EID_KLIENT_ROOT / "lib/libCardAPI.so"
    if not card_api.exists():
        return None
    try:
        data = card_api.read_bytes()
    except Exception:
        return None
    tagged = re.findall(rb"v(\d+\.\d+[_-](?:RC|GA|alpha|beta|rc)\d+)", data, re.IGNORECASE)
    if tagged:
        return tagged[0].decode().replace("_", " ")
    # Fall back: prefer X.Y.Z over bare X.Y (the latter are profile checks)
    xyz = re.findall(rb"\bv(\d+\.\d+\.\d+)\b", data)
    if xyz:
        return xyz[0].decode()
    return None


def status_eid_klient() -> dict:
    return {
        "installed": EID_KLIENT_ROOT.exists(),
        "version": detect_eid_version(),
        "wrapper": WRAPPER_EID.exists(),
        "pkcs11_link": EID_KLIENT_PKCS11_LINK.is_symlink(),
        "vk_link": EID_KLIENT_VK_LINK.is_symlink(),
    }


# === Component: D.Signer pre-fetch ========================================

NS_DNLP = {"d": "http://www.ditec.sk/ep/products/dlauncher/configuration/dnlp/v1.0"}

def parse_dnlp(xml_bytes: bytes) -> dict:
    """Parse a DITEC product .xml (DNLP manifest)."""
    root = ET.fromstring(xml_bytes)
    # Strip namespace for resilience to schema tweaks
    def loc(tag): return tag.rsplit("}", 1)[-1]
    out = {"product_id": None, "version": None, "archives": [], "depends": []}
    for el in root.iter():
        t = loc(el.tag)
        if t == "Product":
            out["product_id"] = el.get("id") or out["product_id"]
            out["version"] = el.get("version") or out["version"]
        if t == "Id" and out["product_id"] is None:
            out["product_id"] = (el.text or "").strip() or None
        if t == "Version" and out["version"] is None:
            out["version"] = (el.text or "").strip() or None
        if t == "Archive":
            # DITEC's DNLP uses element text for filename, attribute for sha256/platform
            href = el.get("href") or (el.text or "").strip()
            platform = el.get("platform") or ""
            sha = el.get("sha256") or (el.findtext(".//{*}Sha256") or "").strip()
            if href:
                out["archives"].append({"href": href, "platform": platform, "sha256": sha})
        if t == "Depends" or t == "Dependency":
            href = el.get("href") or (el.text or "").strip()
            if href:
                out["depends"].append(href)
    return out


def extract_zip(zip_path: Path, dest: Path) -> None:
    """Extract a zip, restoring the unix permission bits stored in each entry
    (masked by umask, like unzip(1)). zipfile.extractall() ignores stored modes
    and falls back to umask defaults, which strips +x from the Zulu JRE binaries
    (bin/java, keytool, lib/jspawnhelper, lib/jexec) — D.Signer then dies with
    'execve: Permission denied' when it launches java."""
    umask = os.umask(0)
    os.umask(umask)
    with zipfile.ZipFile(zip_path) as zf:
        for zi in zf.infolist():
            out = Path(zf.extract(zi, dest))
            mode = (zi.external_attr >> 16) & 0o7777
            if mode:
                out.chmod(mode & ~umask)


def install_xint_wrapper(jre_bin: Path) -> None:
    """Replace <jre>/bin/java with a wrapper forcing -Xint (interpreter only).

    Under muvm/FEX the JVM's C1/C2 JIT emits x86 code FEX mistranslates, so
    D.Signer SIGSEGVs in compiled BigInteger/String methods after a few
    signatures (the JIT only kicks in once methods get hot). The template
    interpreter is stable, so -Xint avoids the crash. Idempotent and
    re-extract-safe: detects whether bin/java is already the wrapper or a
    freshly-extracted ELF."""
    java = jre_bin / "java"
    real = jre_bin / "java.bin"
    if java.is_file():
        with open(java, "rb") as fh:
            is_wrapper = fh.read(2) == b"#!"
        if not is_wrapper:          # fresh ELF -> stash as java.bin (overwrite any old)
            java.replace(real)
    if not real.exists():
        warn(f"{java} not found; skipping -Xint wrapper")
        return
    real.chmod(0o755)
    java.write_text(
        "#!/bin/sh\n"
        "# eid-stack: interpreter-only (-Xint). The JVM JIT emits x86 code that\n"
        "# muvm/FEX mistranslates -> D.Signer SIGSEGV after a few signatures.\n"
        f'exec "{real}" -Xint "$@"\n'
    )
    java.chmod(0o755)
    ok(f"wrapped {java} with -Xint (FEX JIT workaround)")


def install_dsigner() -> None:
    """Pre-fetch D.Signer Java + Zulu JRE 21 into ~/.ditec/dlauncher2/products/.
    Best-effort: D.Launcher may still re-verify on first sign, but the files
    will already be present locally."""
    info("pre-fetching D.Signer Java + Zulu JRE 21")

    versions = {}
    for label, url in [("dsigner", URL_DSIGNER_XML), ("djre", URL_DJRE_XML)]:
        xml_bytes, _ = http_get(url)
        manifest = parse_dnlp(xml_bytes)
        if not manifest["product_id"] or not manifest["version"]:
            die(f"failed to parse manifest at {url}")
        info(f"{manifest['product_id']} version {manifest['version']}")
        product_dir = DLAUNCHER_PRODUCTS / manifest["product_id"] / manifest["version"]
        product_dir.mkdir(parents=True, exist_ok=True)
        # Place the manifest itself
        (product_dir / f"{manifest['product_id']}.xml").write_bytes(xml_bytes)
        # Choose the linux-x86_64 archive
        archive = next((a for a in manifest["archives"] if a["platform"] == "linux-x86_64"), None)
        generic  = next((a for a in manifest["archives"] if not a["platform"]), None)
        # Pick whichever exists; some products only ship generic
        archives = [a for a in (generic, archive) if a]
        if not archives:
            die(f"no linux-x86_64 or generic archive in {url}")
        for arch in archives:
            href = arch["href"]
            zip_url = urllib_join(url, href)
            zip_path = product_dir / Path(href).name
            if zip_path.exists() and arch["sha256"]:
                got = sha256_b64_file(zip_path)
                if got == arch["sha256"]:
                    ok(f"{zip_path.name}: cached, sha256 matches")
                    continue
            download(zip_url, zip_path)
            if arch["sha256"]:
                got = sha256_b64_file(zip_path)
                if got != arch["sha256"]:
                    die(f"sha256 mismatch for {zip_path.name}\n   expected {arch['sha256']}\n   got      {got}")
                ok(f"{zip_path.name}: sha256 verified")
            # Extract zip into product_dir (the launcher expects unpacked content here)
            info(f"extract {zip_path.name}")
            extract_zip(zip_path, product_dir)
        versions[manifest["product_id"]] = manifest["version"]
        ok(f"laid down {product_dir}")

    # Force the bundled JRE into interpreter-only mode (FEX JIT SIGSEGV workaround).
    djre_ver = versions.get("sk.ditec.djre21")
    if djre_ver:
        install_xint_wrapper(DLAUNCHER_PRODUCTS / "sk.ditec.djre21" / djre_ver / "bin")

    state_set("dsigner",
              dsigner_version=versions.get("sk.ditec.ep.products.dsigner.java"),
              djre_version=versions.get("sk.ditec.djre21"))


def uninstall_dsigner() -> None:
    if not DLAUNCHER_PRODUCTS.exists():
        state_drop("dsigner")
        return
    for sub in ("sk.ditec.ep.products.dsigner.java", "sk.ditec.djre21"):
        target = DLAUNCHER_PRODUCTS / sub
        if target.exists():
            shutil.rmtree(target)
            ok(f"removed {target}")
    state_drop("dsigner")


def status_dsigner() -> dict:
    dsigner_dir = DLAUNCHER_PRODUCTS / "sk.ditec.ep.products.dsigner.java"
    djre_dir = DLAUNCHER_PRODUCTS / "sk.ditec.djre21"
    out = {"installed": False, "dsigner": None, "djre": None}
    if dsigner_dir.is_dir():
        versions = sorted(p.name for p in dsigner_dir.iterdir() if p.is_dir())
        if versions:
            out["dsigner"] = versions[-1]
    if djre_dir.is_dir():
        versions = sorted(p.name for p in djre_dir.iterdir() if p.is_dir())
        if versions:
            out["djre"] = versions[-1]
    out["installed"] = bool(out["dsigner"] and out["djre"])
    return out


def urllib_join(base: str, ref: str) -> str:
    from urllib.parse import urljoin
    return urljoin(base, ref)


# === Component: Disig WebSigner ===========================================
#
# WebSigner is installed system-wide by its own .deb (/opt/disig/websigner/,
# root-owned). Its launchers exec the x86_64 binaries directly, which abort
# with "<jemalloc>: Unsupported system page size" on this 16K-page host. This
# component re-points them through the persistent muvm microVM — same trick as
# dBridge2Nm / eID_Client. `update websigner` (and `install` on a box without it)
# downloads Disig's amd64 .deb and extracts its payload over /opt/disig/websigner
# via sudo; `reinstall websigner` does only the re-point (no download/sudo). The
# re-point writes user-side wrapper scripts, fixes the tray autostart entry,
# writes a user-level menu .desktop that shadows the root-owned one, and rewrites
# the browser native-messaging manifests' "path" to the wrappers.

WRAPPER_WEBSIGNER_TRAY_BODY = """\
#!/bin/sh
# Disig WebSigner tray, launched inside the persistent muvm microVM.
# Generated by eid-stack. Edits will be overwritten on update/reinstall.

exec %MUVM% -i -- env \\
    LD_LIBRARY_PATH=%WS_ROOT%/lib \\
    QT_QPA_PLATFORM=xcb \\
    %WS_ROOT%/bin/WebSignerTray "$@"
"""

WRAPPER_WEBSIGNER_NM_BODY = """\
#!/bin/sh
# Disig WebSigner native-messaging host, launched inside the persistent muvm
# microVM. Generated by eid-stack. Edits overwritten on update/reinstall.

exec %MUVM% -i -- env \\
    LD_LIBRARY_PATH=%WS_ROOT%/lib \\
    QT_QPA_PLATFORM=xcb \\
    %WS_ROOT%/bin/WebSigner "$@"
"""


def _websigner_autostart_bak() -> Path:
    return WEBSIGNER_AUTOSTART.parent / (WEBSIGNER_AUTOSTART.name + ".eid-stack.bak")


def detect_websigner_version() -> Optional[str]:
    """Read <Version> out of /opt/disig/websigner/etc/WebSigner.conf."""
    conf = WEBSIGNER_ROOT / "etc/WebSigner.conf"
    if not conf.exists():
        return None
    try:
        root = ET.fromstring(conf.read_text())
    except Exception:
        return None
    for el in root.iter():
        if el.tag.rsplit("}", 1)[-1] == "Version" and (el.text or "").strip():
            return el.text.strip()
    return None


def latest_websigner_version() -> Optional[str]:
    """Parse <version> out of Disig's version-linux.xml update manifest."""
    try:
        xml_bytes, _ = http_get(URL_WEBSIGNER_VERSION_XML)
        root = ET.fromstring(xml_bytes)
    except Exception as e:
        warn(f"WebSigner version check failed: {e}")
        return None
    for el in root.iter():
        if el.tag.rsplit("}", 1)[-1] == "version" and (el.text or "").strip():
            return el.text.strip()
    return None


def update_websigner_deb(force: bool = False) -> bool:
    """Download Disig's amd64 .deb and extract its payload over /opt/disig/websigner.

    WebSigner's own updater is unusable on this box: it installs the .deb by
    shelling out to gdebi, but (a) gdebi isn't installed, (b) the .deb is amd64
    on an arm64 host so dpkg would reject it anyway, and (c) /opt/disig/websigner
    isn't even dpkg-registered — it was laid down by manual extraction. Disig
    publishes no arm64 build, so the amd64 binaries (run through muvm) are all we
    get. We replicate a package install by hand: dpkg-deb -x into a staging dir,
    then sudo-copy opt/disig/websigner/ over the live tree. Returns True if the
    payload was (re)written, False if already current and not forced."""
    need_cmd("dpkg-deb")
    need_cmd("sudo")
    installed = detect_websigner_version()
    latest = latest_websigner_version()
    if installed and latest and installed == latest and not force:
        ok(f"WebSigner {installed} payload is current")
        return False
    info(f"WebSigner payload: {installed or 'not present'} → {latest or 'unknown'}")

    with tempfile.TemporaryDirectory() as td:
        td = Path(td)
        deb = td / "disig-web-signer_amd64.deb"
        download(URL_WEBSIGNER_DEB, deb)
        stage = td / "stage"
        stage.mkdir()
        info(f"extract {deb.name}")
        run(["dpkg-deb", "-x", str(deb), str(stage)])
        payload = stage / "opt/disig/websigner"
        if not payload.is_dir():
            die(f"{deb.name} did not contain opt/disig/websigner/")
        info(f"installing payload over {WEBSIGNER_ROOT} — you'll be prompted for sudo")
        run(["sudo", "rm", "-rf", str(WEBSIGNER_ROOT)])
        run(["sudo", "mkdir", "-p", str(WEBSIGNER_ROOT.parent)])
        run(["sudo", "cp", "-a", str(payload), str(WEBSIGNER_ROOT)])
        run(["sudo", "chown", "-R", "root:root", str(WEBSIGNER_ROOT)])
    new_ver = detect_websigner_version()
    ok(f"WebSigner payload updated → {new_ver or 'unknown'}")
    return True


def fix_websigner_autostart() -> None:
    """Rewrite the user autostart entry so the tray launches through muvm.
    The original (vendor) entry is backed up once. Note: WebSignerTray itself
    re-creates this file from /opt/disig/.../share on its own runs, so this may
    need re-applying after a WebSigner update (`eid-stack reinstall websigner`)."""
    src = WEBSIGNER_ROOT / "share/applications/sk.disig.WebSigner.desktop"
    WEBSIGNER_AUTOSTART.parent.mkdir(parents=True, exist_ok=True)
    if WEBSIGNER_AUTOSTART.exists():
        text = WEBSIGNER_AUTOSTART.read_text()
        bak = _websigner_autostart_bak()
        if not bak.exists() and str(WRAPPER_WEBSIGNER_TRAY) not in text:
            bak.write_text(text)
            ok(f"backed up original autostart → {bak}")
    elif src.exists():
        text = src.read_text()
    else:
        text = ("[Desktop Entry]\nType=Application\nName=Web Signer\n"
                f"Icon={WEBSIGNER_ROOT}/share/icons/WebSigner.png\nTerminal=false\n")

    lines, seen = [], set()
    for line in text.splitlines():
        if line.startswith(("Exec=", "TryExec=")):
            key = line.split("=", 1)[0]
            lines.append(f"{key}={WRAPPER_WEBSIGNER_TRAY}")
            seen.add(key)
        else:
            lines.append(line)
    for key in ("Exec", "TryExec"):
        if key not in seen:
            lines.append(f"{key}={WRAPPER_WEBSIGNER_TRAY}")
    WEBSIGNER_AUTOSTART.write_text("\n".join(lines) + "\n")
    WEBSIGNER_AUTOSTART.chmod(0o644)
    ok(f"re-pointed autostart {WEBSIGNER_AUTOSTART} → {WRAPPER_WEBSIGNER_TRAY}")


def fix_websigner_menu_entry() -> None:
    """Write a user-level menu .desktop that shadows the root-owned
    /usr/share/applications/sk.disig.WebSigner.desktop. The .deb (and WebSigner's
    own updater) keep resetting that system file to exec the native x86_64
    WebSignerTray.sh, which aborts with jemalloc's page-size error on this 16K
    host. A user-level entry of the same name takes XDG precedence and — unlike
    sudo-editing /usr/share — survives future .deb updates. Nothing to back up:
    the system file underneath is left untouched. Also forces a Categories= line
    so the entry doesn't land in the desktop menu's "Lost & Found"."""
    src = WEBSIGNER_ROOT / "share/applications/sk.disig.WebSigner.desktop"
    if src.exists():
        text = src.read_text()
    else:
        text = ("[Desktop Entry]\nType=Application\nName=Web Signer\n"
                f"Icon={WEBSIGNER_ROOT}/share/icons/WebSigner.png\nTerminal=false\n")

    lines, seen, has_categories = [], set(), False
    for line in text.splitlines():
        if line.startswith(("Exec=", "TryExec=")):
            key = line.split("=", 1)[0]
            lines.append(f"{key}={WRAPPER_WEBSIGNER_TRAY}")
            seen.add(key)
        else:
            if line.startswith("Categories="):
                has_categories = True
            lines.append(line)
    for key in ("Exec", "TryExec"):
        if key not in seen:
            lines.append(f"{key}={WRAPPER_WEBSIGNER_TRAY}")
    if not has_categories:
        lines.append("Categories=Utility;Security;")

    DESKTOP_DIR.mkdir(parents=True, exist_ok=True)
    WEBSIGNER_MENU_ENTRY.write_text("\n".join(lines) + "\n")
    WEBSIGNER_MENU_ENTRY.chmod(0o644)
    ok(f"re-pointed menu entry {WEBSIGNER_MENU_ENTRY} → {WRAPPER_WEBSIGNER_TRAY}")


def write_websigner_nm_manifests() -> list[Path]:
    """Copy Disig's NM manifests into installed browsers, rewriting their
    `path` to our muvm wrapper instead of the crashing /opt/disig WebSigner.sh."""
    written: list[Path] = []

    def place(srcs: list[Path], dirpath: Path) -> None:
        for src in srcs:
            try:
                manifest = json.loads(src.read_text())
            except Exception as e:
                warn(f"skip {src.name}: {e}")
                continue
            manifest["path"] = str(WRAPPER_WEBSIGNER_NM)
            dirpath.mkdir(parents=True, exist_ok=True)
            target = dirpath / src.name
            target.write_text(json.dumps(manifest, indent=2) + "\n")
            target.chmod(0o644)
            written.append(target)
            ok(f"wrote NM manifest: {target}")

    chrome_src = sorted((WEBSIGNER_ROOT / "chrome").glob("sk.disig.websigner.*.json"))
    for name, dirpath in NM_BROWSERS.items():
        # write into any browser whose config root exists, OR brave (recommended)
        if dirpath.parent.parent.exists() or name == "brave":
            place(chrome_src, dirpath)

    firefox_src = sorted((WEBSIGNER_ROOT / "firefox").glob("sk.disig.websigner.*.json"))
    if (HOME / ".mozilla").is_dir():
        place(firefox_src, FIREFOX_NM_DIR)

    return written


def install_websigner() -> None:
    if not WEBSIGNER_ROOT.is_dir():
        info(f"{WEBSIGNER_ROOT} not present — fetching Disig's .deb")
        update_websigner_deb(force=True)
    if not WEBSIGNER_ROOT.is_dir():
        die(f"Disig WebSigner still not found at {WEBSIGNER_ROOT} after download.")
    need_cmd("muvm")
    muvm = muvm_path()

    for wrapper, body in ((WRAPPER_WEBSIGNER_TRAY, WRAPPER_WEBSIGNER_TRAY_BODY),
                          (WRAPPER_WEBSIGNER_NM, WRAPPER_WEBSIGNER_NM_BODY)):
        wrapper.parent.mkdir(parents=True, exist_ok=True)
        wrapper.write_text(body
                           .replace("%MUVM%", str(muvm))
                           .replace("%WS_ROOT%", str(WEBSIGNER_ROOT)))
        wrapper.chmod(0o755)
        ok(f"wrote wrapper {wrapper}")

    fix_websigner_autostart()
    fix_websigner_menu_entry()
    write_websigner_nm_manifests()

    version = detect_websigner_version()
    state_set("websigner", source=str(WEBSIGNER_ROOT), version=version)
    ok(f"Disig WebSigner version: {version or 'unknown'}")


def uninstall_websigner() -> None:
    bak = _websigner_autostart_bak()
    if bak.exists():
        WEBSIGNER_AUTOSTART.parent.mkdir(parents=True, exist_ok=True)
        WEBSIGNER_AUTOSTART.write_text(bak.read_text())
        bak.unlink()
        ok(f"restored original autostart {WEBSIGNER_AUTOSTART}")
    else:
        remove_path(WEBSIGNER_AUTOSTART)
    remove_path(WEBSIGNER_MENU_ENTRY)
    remove_path(WRAPPER_WEBSIGNER_TRAY)
    remove_path(WRAPPER_WEBSIGNER_NM)
    for dirpath in list(NM_BROWSERS.values()) + [FIREFOX_NM_DIR]:
        if dirpath.is_dir():
            for p in dirpath.glob("sk.disig.websigner.*.json"):
                p.unlink(missing_ok=True)
                ok(f"removed {p}")
    state_drop("websigner")


def status_websigner() -> dict:
    autostart_fixed = (WEBSIGNER_AUTOSTART.exists()
                       and str(WRAPPER_WEBSIGNER_TRAY) in WEBSIGNER_AUTOSTART.read_text())
    menu_entry_fixed = (WEBSIGNER_MENU_ENTRY.exists()
                        and str(WRAPPER_WEBSIGNER_TRAY) in WEBSIGNER_MENU_ENTRY.read_text())
    return {
        "installed": WEBSIGNER_ROOT.is_dir() and WRAPPER_WEBSIGNER_TRAY.exists(),
        "present": WEBSIGNER_ROOT.is_dir(),
        "version": detect_websigner_version(),
        "tray_wrapper": WRAPPER_WEBSIGNER_TRAY.exists(),
        "nm_wrapper": WRAPPER_WEBSIGNER_NM.exists(),
        "autostart_fixed": autostart_fixed,
        "menu_entry_fixed": menu_entry_fixed,
    }


