def is_changed(component: str, url: str) -> Optional[bool]:
    s = state_load().get(component, {})
    try:
        h = http_head(url)
    except Exception as e:
        warn(f"HEAD {url}: {e}")
        return None
    et_new = h.get("ETag")
    lm_new = h.get("Last-Modified")
    et_old = s.get("etag")
    lm_old = s.get("last_modified")
    if et_new and et_old and et_new != et_old:
        return True
    if lm_new and lm_old and lm_new != lm_old:
        return True
    if et_new and et_old and et_new == et_old:
        return False
    if lm_new and lm_old and lm_new == lm_old:
        return False
    return None  # unknown


def _tilde(p) -> str:
    """Contract $HOME to ~ for list-display paths."""
    s = str(p)
    h = str(HOME)
    return "~" + s[len(h):] if s == h or s.startswith(h + "/") else s


# Per-component install root surfaced in `list`. Picked for "where do I look on
# disk for this component" — for muvm-service that's the muvm binary itself
# (the systemd unit and the ~/.local/bin/muvm-guest symlink are just glue).
COMPONENT_PATH = {
    "muvm-service": HOME / ".cargo/bin/muvm",
    "dlauncher":    DLAUNCHER_ROOT,
    "eid-klient":   EID_KLIENT_ROOT,
    "dsigner":      DLAUNCHER_PRODUCTS,
    "websigner":    WEBSIGNER_ROOT,
}


def cmd_list() -> None:
    s = state_load()
    rows = []
    for comp in ALL_COMPONENTS:
        if comp == "muvm-service":
            st = status_muvm_service()
            installed = "yes" if st["installed"] else "no"
            extra = "active" if st["active"] else "inactive" if st["installed"] else "—"
            if st["active"] and not st["shim_active"]:
                extra += " (no ipv6 shim)"
            update = "—"
        elif comp == "dlauncher":
            st = status_dlauncher()
            installed = "yes" if st.get("installed") else "no"
            extra = (st.get("version") or "unknown") if st.get("installed") else "—"
            update = _fmt_update(is_changed("dlauncher", URL_DLAUNCHER)) if st.get("installed") else "—"
        elif comp == "eid-klient":
            st = status_eid_klient()
            installed = "yes" if st.get("installed") else "no"
            extra = (st.get("version") or "unknown") if st.get("installed") else "—"
            update = _fmt_update(is_changed("eid-klient", URL_EID_KLIENT)) if st.get("installed") else "—"
        elif comp == "dsigner":
            st = status_dsigner()
            installed = "yes" if st.get("installed") else "no"
            extra = f"D.Signer {st.get('dsigner') or '—'} / JRE {st.get('djre') or '—'}" if st.get("installed") else "—"
            # For dsigner, "update" check would need to re-parse the XML; do a HEAD on the XML
            update = _fmt_update(is_changed("dsigner-xml", URL_DSIGNER_XML)) if st.get("installed") else "—"
        elif comp == "websigner":
            st = status_websigner()
            installed = "yes" if st.get("installed") else "no"
            if st.get("installed"):
                ver = st.get("version") or "unknown"
                extra = ver if st.get("autostart_fixed") else f"{ver} (autostart NOT fixed)"
            elif st.get("present"):
                extra = "present, not wired"
            else:
                extra = "—"
            if st.get("installed") or st.get("present"):
                inst_v, latest_v = detect_websigner_version(), latest_websigner_version()
                if inst_v and latest_v:
                    update = "current" if inst_v == latest_v else f"newer ({latest_v})"
                else:
                    update = "?"
            else:
                update = "—"
        else:
            continue
        path = COMPONENT_PATH[comp]
        path_str = _tilde(path) if path.exists() else f"{_tilde(path)} (missing)"
        rows.append((comp, installed, extra, update, path_str))

    headers = ("component", "installed", "version/state", "upstream", "path")
    cols = list(zip(*rows))
    widths = [max(len(h), *(len(str(x)) for x in col)) for h, col in zip(headers, cols)]
    fmt = lambda cells: "  ".join(str(c).ljust(w) for c, w in zip(cells, widths)).rstrip()
    # Underline spans the widest row, not the (rstripped) header — the header's
    # last column ("path") is usually shorter than the longest path value.
    total_width = sum(widths) + 2 * (len(widths) - 1)
    print(fmt(headers))
    print("-" * total_width)
    for row in rows:
        print(fmt(row))


def _fmt_update(changed: Optional[bool]) -> str:
    if changed is None:
        return "?"
    return "newer" if changed else "current"


