def remove_path(p: Path) -> None:
    if p.is_symlink() or p.exists():
        if p.is_dir() and not p.is_symlink():
            shutil.rmtree(p)
        else:
            p.unlink(missing_ok=True)
        ok(f"removed {p}")


def cmd_install(comps: list[str]) -> None:
    for c in [x for x in INSTALL_ORDER if x in comps]:
        info(f"=== installing {c} ===")
        INSTALLERS[c]()


def cmd_uninstall(comps: list[str]) -> None:
    for c in [x for x in UNINSTALL_ORDER if x in comps]:
        info(f"=== uninstalling {c} ===")
        UNINSTALLERS[c]()


def cmd_reinstall(comps: list[str]) -> None:
    cmd_uninstall(comps)
    cmd_install(comps)


def cmd_update(comps: list[str]) -> None:
    state = state_load()
    to_update = []
    for c in comps:
        if c not in state:
            warn(f"{c} not installed; skipping (use 'install' instead)")
            continue
        if c == "muvm-service":
            # No upstream URL tracked — just re-apply the generated unit/wrappers.
            to_update.append(c)
            continue
        if c == "websigner":
            # WebSigner's own updater can't run here (gdebi + amd64 .deb — see
            # update_websigner_deb). Fetch + extract the .deb ourselves, then
            # fall through to reinstall so the muvm re-point is re-applied.
            update_websigner_deb()
            to_update.append(c)
            continue
        url = UPSTREAM_URL[c]
        changed = is_changed(c, url)
        if changed is None:
            warn(f"{c}: cannot determine if upstream changed; updating anyway")
            to_update.append(c)
        elif changed:
            info(f"{c}: upstream changed; updating")
            to_update.append(c)
        else:
            ok(f"{c}: up to date")
    if to_update:
        cmd_reinstall(to_update)


